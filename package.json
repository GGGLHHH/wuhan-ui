{
  "name": "wuhan-ui",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/website",
    "tools/*"
  ],
  "type": "module",
  "scripts": {
    "ready": "vp fmt && vp lint && vp run test -r && vp run build -r",
    "test": "vp run test -r",
    "dev": "vp run website#dev",
    "prepare": "vp config",
    "fmt": "vp fmt",
    "check:fix": "vp lint --fix --fix-suggestions --fix-dangerously && vp check --fix"
  },
  "devDependencies": {
    "vite-plus": "catalog:"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@10.32.1"
}
