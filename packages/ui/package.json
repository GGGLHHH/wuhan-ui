{
  "name": "@gedatou/ui",
  "version": "0.0.14",
  "description": "A starter for creating a TypeScript package.",
  "homepage": "https://github.com/GGGLHHH/wuhan-ui#readme",
  "bugs": {
    "url": "https://github.com/GGGLHHH/wuhan-ui/issues"
  },
  "license": "MIT",
  "author": "ge Datou (https://github.com/GGGLHHH)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GGGLHHH/wuhan-ui.git"
  },
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    },
    "./styles.css": "./src/index.css",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "gen": "vp exec tsx scripts/gen-index.ts",
    "build": "vp exec tsx scripts/gen-index.ts && vp pack",
    "dev": "vp exec tsx scripts/gen-index.ts --watch & vp pack --watch",
    "test": "vp test",
    "typecheck": "tsc --noEmit",
    "release": "bumpp --no-verify",
    "prepublishOnly": "vp run build"
  },
  "dependencies": {
    "@base-ui/react": "catalog:",
    "@fontsource-variable/geist": "catalog:",
    "@fontsource-variable/inter": "catalog:",
    "@lottiefiles/dotlottie-react": "catalog:",
    "@react-three/fiber": "catalog:",
    "class-variance-authority": "catalog:",
    "clsx": "catalog:",
    "cmdk": "catalog:",
    "date-fns": "catalog:",
    "embla-carousel-react": "catalog:",
    "input-otp": "catalog:",
    "lucide-react": "catalog:",
    "motion": "^12.38.0",
    "next-themes": "catalog:",
    "ogl": "catalog:",
    "radix-ui": "catalog:",
    "react-day-picker": "catalog:",
    "react-resizable-panels": "catalog:",
    "recharts": "2.15.4",
    "sonner": "catalog:",
    "tailwind-merge": "catalog:",
    "tailwindcss": "catalog:",
    "three": "catalog:",
    "tw-animate-css": "catalog:",
    "vaul": "catalog:"
  },
  "devDependencies": {
    "@tailwindcss/vite": "catalog:",
    "@tsdown/css": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@types/three": "catalog:",
    "@typescript/native-preview": "catalog:",
    "bumpp": "catalog:",
    "shadcn": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  }
}
