{
  "name": "@gedatou/ui",
  "version": "0.0.5",
  "description": "A starter for creating a TypeScript package.",
  "homepage": "https://github.com/GGGLHHH/wuhan-ui#readme",
  "bugs": {
    "url": "https://github.com/GGGLHHH/wuhan-ui/issues"
  },
  "license": "MIT",
  "author": "ge Datou (https://github.com/GGGLHHH)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GGGLHHH/wuhan-ui.git"
  },
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    },
    "./styles.css": "./src/index.css",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "gen": "vp exec tsx scripts/gen-index.ts",
    "build": "vp exec tsx scripts/gen-index.ts && vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "typecheck": "tsc --noEmit",
    "release": "bumpp --no-verify",
    "prepublishOnly": "vp run build"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/inter": "^5.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.577.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react-day-picker": "^9.14.0",
    "react-resizable-panels": "^4.7.3",
    "recharts": "^2.15.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@tsdown/css": "^0.21.3",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260316.1",
    "bumpp": "^11.0.1",
    "shadcn": "^4.0.8",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite-plus": "latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  }
}
